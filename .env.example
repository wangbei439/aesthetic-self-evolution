# Database
DATABASE_URL="file:./db/custom.db"

# ==============================================================================
# AI Provider Configuration
# ==============================================================================
# This project supports multiple AI backends via an adapter layer.
# Choose ONE provider and configure it below.
#
# Available providers:
#   zai        - Z.ai Sandbox (auto-detected, no key needed) — default in sandbox
#   zhipu      - 智谱 GLM (ZhipuAI) — recommended for Chinese users
#   openai     - OpenAI (GPT-4o, etc.)
#   deepseek   - DeepSeek
#   moonshot   - Moonshot (月之暗面)
#   siliconflow - SiliconFlow (硅基流动)
#   custom     - Any OpenAI-compatible API
# ==============================================================================

# --- Option 1: Z.ai Sandbox (no configuration needed) ---
# If running in Z.ai sandbox, leave AI_PROVIDER empty or set to "zai"
# The SDK handles authentication automatically.
AI_PROVIDER=

# --- Option 2: 智谱 GLM (recommended for GitHub deployment) ---
# Sign up at https://open.bigmodel.cn/ to get your API key
# AI_PROVIDER=zhipu
# AI_API_KEY=your_zhipu_api_key_here

# --- Option 3: OpenAI ---
# AI_PROVIDER=openai
# AI_API_KEY=your_openai_api_key_here

# --- Option 4: DeepSeek ---
# AI_PROVIDER=deepseek
# AI_API_KEY=your_deepseek_api_key_here

# --- Option 5: Moonshot ---
# AI_PROVIDER=moonshot
# AI_API_KEY=your_moonshot_api_key_here

# --- Option 6: SiliconFlow ---
# AI_PROVIDER=siliconflow
# AI_API_KEY=your_siliconflow_api_key_here

# --- Option 7: Custom OpenAI-compatible API ---
# AI_PROVIDER=custom
# AI_API_KEY=your_api_key_here
# AI_BASE_URL=https://your-api.com/v1
# AI_VLM_MODEL=your-vlm-model-id
# AI_LLM_MODEL=your-llm-model-id

# --- Optional overrides (for any provider) ---
# AI_BASE_URL=          # Override base URL for any preset provider
# AI_VLM_MODEL=         # Override VLM model ID
# AI_LLM_MODEL=         # Override LLM model ID
# AI_PROVIDER_LABEL=    # Custom display label for the provider
