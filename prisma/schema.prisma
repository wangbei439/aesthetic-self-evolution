generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 审美家族：6大域分割
model AestheticFamily {
  id          String   @id @default(cuid())
  key         String   @unique   // narrative_visual, interactive_ui, spatial, character, graphic_composition, dynamic_rhythm
  name        String             // 叙事视觉, 交互界面, 空间营造, 人物造型, 平面构成, 动态韵律
  description String             // 家族描述
  icon        String             // Lucide icon name
  color       String             // 代表色 (Tailwind color class)
  criteria    String             // JSON: 该家族的审美评价维度定义
  domains     String             // JSON: 包含的域列表
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  evaluations AestheticEvaluation[]
  rules       AestheticRule[]
}

// 审美评估记录
model AestheticEvaluation {
  id          String   @id @default(cuid())
  familyId    String
  family      AestheticFamily @relation(fields: [familyId], references: [id])

  imageUrl    String             // 被评估的图片URL或base64
  imageHash   String?            // 图片hash，用于去重

  // 域分类结果
  detectedDomain String?         // 检测到的具体域
  domainConfidence Float @default(0) // 域检测置信度

  // 评估结果 (JSON)
  overallScore   Float @default(0)   // 总分 0-10
  dimensionScores String            // JSON: 各维度评分 {composition: 8, color: 7, ...}
  evaluation      String            // 自然语言评估
  suggestions     String            // JSON: 改进建议列表
  strengths       String            // JSON: 优点列表
  weaknesses      String            // JSON: 不足列表

  // 进化相关
  evolutionGeneration Int @default(1)  // 第几代评估
  ruleVersionUsed     String?          // 使用的法则版本
  humanFeedback       String?          // JSON: 人工反馈
  humanScoreOverride  Float?           // 人工修正分数

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 审美法则：每个家族的进化法则库
model AestheticRule {
  id          String   @id @default(cuid())
  familyId    String
  family      AestheticFamily @relation(fields: [familyId], references: [id])

  ruleContent String             // 法则内容（自然语言描述）
  ruleType    String             // positive | negative | conditional
  dimension   String?            // 关联的审美维度
  priority    Float @default(0.5) // 优先级/权重 0-1

  // 进化追踪
  generation  Int @default(1)    // 第几代法则
  parentId    String?            // 父法则ID（进化来源）
  sourceType  String @default("seed") // seed | evolved | human | transferred
  sourceFamilyId String?         // 如果是跨家族迁移，来源家族ID

  // 验证状态
  supportCount    Int @default(0)    // 支持该法则的评估次数
  contradictCount Int @default(0)    // 反对该法则的评估次数
  confidence      Float @default(0.5) // 置信度
  status          String @default("active") // active | deprecated | candidate

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 进化事件：追踪进化循环的每一步
model EvolutionEvent {
  id          String   @id @default(cuid())
  familyId    String?             // 关联的家族（null表示跨家族事件）

  eventType   String              // reflection | rule_created | rule_modified | rule_deprecated | rule_promoted | transfer_attempt | transfer_success | transfer_failed | crawl_discovered | crawl_evaluated | auto_evolve
  description String              // 事件描述
  metadata    String?             // JSON: 事件相关数据

  generation  Int @default(1)     // 第几代
  createdAt   DateTime @default(now())
}

// ---------------------------------------------------------------------------
// 自动爬取 & 自进化相关模型
// ---------------------------------------------------------------------------

// 爬取数据源：配置从哪里获取审美训练数据
model CrawlSource {
  id          String   @id @default(cuid())
  name        String             // 数据源名称
  type        String             // search | gallery | rss | custom
  familyKey   String?            // 关联的审美家族key（null表示全家族通用）
  
  // 搜索配置
  query       String?            // Web Search 搜索关键词
  targetUrls  String?            // JSON: 目标网站URL列表
  maxItems    Int @default(10)   // 每次爬取最大条目数
  
  // 状态
  status      String @default("active")   // active | paused | error
  lastCrawledAt DateTime?         // 上次爬取时间
  totalFound   Int @default(0)    // 累计发现条目数
  totalEvaluated Int @default(0)  // 累计评估条目数
  
  // 配置
  config      String?            // JSON: 额外配置（如过滤条件、语言偏好等）
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks       CrawlTask[]
  items       CrawledItem[]
}

// 爬取任务：每次执行爬取的记录
model CrawlTask {
  id          String   @id @default(cuid())
  sourceId    String
  source      CrawlSource @relation(fields: [sourceId], references: [id])
  
  status      String @default("pending")  // pending | running | completed | failed
  startedAt   DateTime?
  completedAt DateTime?
  
  // 执行结果
  itemsFound     Int @default(0)      // 发现的条目数
  itemsEvaluated Int @default(0)      // 成功评估的条目数
  itemsSkipped   Int @default(0)      // 跳过的条目数（重复、无效等）
  itemsFailed    Int @default(0)      // 评估失败的条目数
  
  // 错误信息
  error       String?            // 错误描述
  
  // 触发方式
  trigger     String @default("manual")  // manual | scheduled | auto_evolve
  
  // 进化结果（如果触发了自动进化）
  evolutionTriggered Boolean @default(false) // 是否触发了进化
  rulesCreated       Int @default(0)         // 进化产生的新规则数
  rulesDeprecated    Int @default(0)         // 进化废弃的规则数
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       CrawledItem[]
}

// 爬取条目：发现的图片/内容
model CrawledItem {
  id          String   @id @default(cuid())
  sourceId    String?
  source      CrawlSource? @relation(fields: [sourceId], references: [id])
  taskId      String?
  task        CrawlTask? @relation(fields: [taskId], references: [id])
  
  // 内容信息
  imageUrl    String             // 图片URL
  title       String?            // 页面/图片标题
  sourceUrl   String?            // 来源页面URL
  description String?            // 内容描述
  
  // 分类结果
  familyKey   String?            // 自动分类到的家族
  familyId    String?            // 关联家族ID
  classificationConfidence Float @default(0)
  
  // 评估状态
  evaluationStatus String @default("pending")  // pending | evaluating | evaluated | failed | skipped
  evaluationId String?            // 关联的评估ID
  overallScore Float?             // 评估得分
  
  // 去重
  imageHash   String?            // 图片hash，用于去重
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
